<Window x:Class="plomfX.Views.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick Color" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Color Preview -->
        <Border x:Name="ColorPreviewBorder" Height="40" CornerRadius="4" Margin="0,0,0,10"
                BorderBrush="{DynamicResource PrimaryBorderBrush}" BorderThickness="1"/>

        <!-- Hex Input -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Hex:" Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center"/>
            <TextBox x:Name="HexTextBox" Grid.Column="1" 
                     Background="{DynamicResource SecondaryAccentBrush}"
                     Foreground="{DynamicResource SecondaryForegroundBrush}"
                     BorderThickness="0" Padding="5"
                     TextChanged="HexTextBox_TextChanged"/>
        </Grid>

        <!-- RGB Sliders -->
        <!-- Red -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="R:" Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center"/>
            <Slider x:Name="RedSlider" Grid.Column="1" Minimum="0" Maximum="255" 
                    Value="255" TickFrequency="1" IsMoveToPointEnabled="True"
                    Margin="10,0"/>
            <TextBox x:Name="RedTextBox" Grid.Column="2" 
                     Text="255" TextAlignment="Right"
                     Background="{DynamicResource SecondaryAccentBrush}"
                     Foreground="{DynamicResource SecondaryForegroundBrush}"
                     BorderThickness="0" Padding="4"/>
        </Grid>

        <!-- Green -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="G:" Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center"/>
            <Slider x:Name="GreenSlider" Grid.Column="1" Minimum="0" Maximum="255" 
                    Value="255" TickFrequency="1" IsMoveToPointEnabled="True"
                    Margin="10,0"/>
            <TextBox x:Name="GreenTextBox" Grid.Column="2" 
                     Text="255" TextAlignment="Right"
                     Background="{DynamicResource SecondaryAccentBrush}"
                     Foreground="{DynamicResource SecondaryForegroundBrush}"
                     BorderThickness="0" Padding="4"/>
        </Grid>

        <!-- Blue -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="B:" Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center"/>
            <Slider x:Name="BlueSlider" Grid.Column="1" Minimum="0" Maximum="255" 
                    Value="255" TickFrequency="1" IsMoveToPointEnabled="True"
                    Margin="10,0"/>
            <TextBox x:Name="BlueTextBox" Grid.Column="2" 
                     Text="255" TextAlignment="Right"
                     Background="{DynamicResource SecondaryAccentBrush}"
                     Foreground="{DynamicResource SecondaryForegroundBrush}"
                     BorderThickness="0" Padding="4"/>
        </Grid>

        <!-- Custom Colors Palette -->
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Saved Colors" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,5"/>
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="CustomColorsPanel" Orientation="Horizontal"/>
            </ScrollViewer>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Width="70" Style="{StaticResource ActionButtonStyle}" Click="Ok_Click" Margin="0,0,10,0"/>
            <Button Content="Cancel" Width="70" Style="{StaticResource ActionButtonStyle}" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>